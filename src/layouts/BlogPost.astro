---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const pubDateObj = pubDate instanceof Date ? pubDate : new Date(pubDate);
const updatedDateObj = updatedDate ? (updatedDate instanceof Date ? updatedDate : new Date(updatedDate)) : undefined;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: min(1080px, calc(100% - 2.5rem));
				margin: 0 auto;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: var(--radius-lg);
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: min(760px, calc(100% - 2rem));
				margin: 1.2rem auto 0;
				padding: 1.4rem;
				background: rgba(var(--surface-1), 0.72);
				border: 1px solid rgba(var(--border), 0.28);
				border-radius: var(--radius-lg);
				box-shadow: var(--surface-shadow);
			}
			.title {
				margin-bottom: 1rem;
				padding: 0.5rem 0 1rem;
				text-align: center;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 720px) {
				main {
					width: min(1080px, calc(100% - 1.5rem));
				}
				.prose {
					width: calc(100% - 1rem);
					padding: 1rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <img width={510} height={205} src={heroImage} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDateObj} />
							{
								updatedDateObj && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDateObj} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<h4><em>{description}</em></h4>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
