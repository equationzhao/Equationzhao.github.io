---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			section {
				padding: 1.2rem;
				background: rgba(var(--surface-1), 0.72);
				border: 1px solid rgba(var(--border), 0.28);
				border-radius: var(--radius-lg);
				box-shadow: var(--surface-shadow);
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				border-radius: var(--radius-md);
				background: rgba(var(--surface-0), 0.55);
				border: 1px solid rgba(var(--border), 0.2);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				grid-column: 1 / -1;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
				padding: 1rem;
			}
			.title {
				margin: 0 0 0.5rem;
				color: rgb(237, 242, 255);
				line-height: 1.2;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul li a:hover {
				transform: translateY(-3px);
			}
			ul li a:hover img {
				box-shadow: 0 0 0 1px rgba(var(--accent), 0.48), 0 10px 24px rgba(4, 8, 22, 0.55);
			}
			@media (max-width: 720px) {
				section {
					padding: 0.8rem;
				}
				ul {
					grid-template-columns: 1fr;
					gap: 0.8rem;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main transition:animate="fade">
			<section>
				<ul>
					{						
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id.replace(/\.md$/, '')}/`} rel = prefetch-intent>
									<div class="hero-image">
										<img width={510} height={205} src={post.data.heroImage} />
									</div>
									<h4 class="title">{post.data.title}</h4>
									<p class="date"><em>{post.data.description}</em></p>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
